{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mocc-se.local/schemas/adjudication.schema.json",
  "title": "MOCC-SE validation adjudication",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adjudication_id",
    "manifest_id",
    "freeze_id",
    "status",
    "label_set_ids",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "adjudication_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "manifest_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "freeze_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "status": { "enum": ["template", "complete"] },
    "label_set_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "final_verdict",
          "adjudicator",
          "rationale",
          "reviewer_verdicts"
        ],
        "properties": {
          "sample_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "final_verdict": {
            "enum": [
              "unlabeled",
              "legal",
              "violation",
              "analysis_unknown",
              "out_of_scope"
            ]
          },
          "adjudicator": { "type": "string" },
          "rationale": { "type": "string" },
          "reviewer_verdicts": {
            "type": "object",
            "additionalProperties": {
              "enum": [
                "unlabeled",
                "legal",
                "violation",
                "analysis_unknown",
                "out_of_scope"
              ]
            }
          }
        }
      }
    }
  }
}
