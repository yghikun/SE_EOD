{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mocc-se.local/schemas/reviewer_labels.schema.json",
  "title": "MOCC-SE independent reviewer labels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "label_set_id",
    "manifest_id",
    "freeze_id",
    "reviewer_slot",
    "label_visibility",
    "status",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "label_set_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "manifest_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "freeze_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "reviewer_slot": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "label_visibility": { "const": "independent" },
    "status": { "enum": ["template", "complete"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "reviewer_slot",
          "verdict",
          "rationale",
          "evidence_notes",
          "analysis_limitations"
        ],
        "properties": {
          "sample_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "reviewer_slot": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "verdict": {
            "enum": [
              "unlabeled",
              "legal",
              "violation",
              "analysis_unknown",
              "out_of_scope"
            ]
          },
          "rationale": { "type": "string" },
          "evidence_notes": { "type": "string" },
          "analysis_limitations": { "type": "string" }
        }
      }
    }
  }
}
