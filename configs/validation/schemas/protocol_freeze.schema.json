{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mocc-se.local/schemas/protocol_freeze.schema.json",
  "title": "MOCC-SE protocol freeze",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "freeze_id",
    "created_at",
    "status",
    "registry_path",
    "protocol_directory",
    "artifacts"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "freeze_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "status": { "const": "frozen" },
    "registry_path": { "type": "string" },
    "protocol_directory": { "type": "string" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "artifact_kind",
          "logical_id",
          "schema_version",
          "semantic_version",
          "content_sha256"
        ],
        "properties": {
          "path": { "type": "string" },
          "artifact_kind": {
            "enum": ["registry", "protocol_manifest", "family", "binding", "operation"]
          },
          "logical_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "schema_version": { "type": "integer", "minimum": 1 },
          "semantic_version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
          },
          "content_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    }
  }
}
