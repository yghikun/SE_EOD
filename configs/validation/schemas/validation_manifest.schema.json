{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mocc-se.local/schemas/validation_manifest.schema.json",
  "title": "MOCC-SE blind validation manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_version",
    "manifest_id",
    "freeze_id",
    "dataset_split",
    "label_visibility",
    "protocol_revision_policy",
    "construction_overlap_policy",
    "samples"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "manifest_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "manifest_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "freeze_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
    "dataset_split": { "enum": ["validation", "frozen_test"] },
    "label_visibility": { "enum": ["blind", "unblinded"] },
    "protocol_revision_policy": { "const": "frozen_before_label_access" },
    "construction_overlap_policy": { "const": "reject_version_path_function_overlap" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sample_id",
          "protocol_id",
          "candidate_rule_ids",
          "filesystem",
          "source_version",
          "source_path",
          "source_sha256",
          "functions",
          "selection_kind",
          "selection_rationale",
          "label_status",
          "reviewer_slots",
          "allowed_verdicts"
        ],
        "properties": {
          "sample_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "protocol_id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "candidate_rule_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" }
          },
          "filesystem": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
          "source_version": { "type": "string" },
          "source_path": { "type": "string" },
          "source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "functions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" }
          },
          "selection_kind": { "enum": ["fresh_discovery", "near_neighbor"] },
          "selection_rationale": { "type": "string", "minLength": 1 },
          "label_status": {
            "enum": ["unlabeled", "independently_labeled", "adjudicated"]
          },
          "reviewer_slots": {
            "type": "array",
            "minItems": 2,
            "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" }
          },
          "allowed_verdicts": {
            "type": "array",
            "contains": { "const": "legal" },
            "items": {
              "enum": ["legal", "violation", "analysis_unknown", "out_of_scope"]
            }
          }
        }
      }
    }
  }
}
