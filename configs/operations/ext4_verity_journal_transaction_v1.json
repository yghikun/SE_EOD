{
  "operation_schema_version": 1,
  "operation_id": "ext4_verity_journal_transaction",
  "family_id": "transaction_lifecycle",
  "binding_id": "ext4.journal_transaction",
  "entry_functions": ["ext4_begin_enable_verity"],
  "phases": ["ENTRY", "SUCCESS", "FAILURE"],
  "role_instances": [
    {"abstract_role": "resource", "selector": "summary-bound"}
  ],
  "discovery": {
    "required_callees": ["ext4_journal_start", "ext4_journal_stop"],
    "semantic_patterns": ["mutation_failure_cleanup"]
  },
  "return_contracts": [
    {"contract_id": "ext4.transaction.failure", "guard": "ret != 0", "outcome": "failure"},
    {"contract_id": "ext4.transaction.success", "guard": "ret == 0", "outcome": "success"}
  ],
  "effect": {
    "event_id": "ext4.journal_handle.open",
    "effect_id": "ext4.journal_handle.lifecycle",
    "abstract_role": "resource",
    "kind": "METADATA_UPDATE",
    "scope": "TRANSACTION_SCOPED",
    "owner": "ext4_journal_manager",
    "phase": "ENTRY",
    "required": true,
    "description": "A successfully started ext4 journal handle must be stopped on every reachable exit."
  },
  "summary_ids": {
    "acquire": "ext4.transaction.start",
    "commit": "ext4.transaction.stop"
  },
  "legal_exits": [
    {
      "exit_id": "ext4.transaction.success",
      "kind": "success",
      "phases": ["SUCCESS"],
      "completion_modes": ["COMMITTED"],
      "return_outcomes": ["success"]
    },
    {
      "exit_id": "ext4.transaction.failure",
      "kind": "failure",
      "phases": ["FAILURE"],
      "completion_modes": ["ROLLED_BACK", "COMMITTED", "ABORTED", "RECOVERY_DELEGATED", "DEFERRED"],
      "return_outcomes": ["failure"]
    }
  ],
  "description": "Development operation instance for the ext4 verity journal transaction."
}
