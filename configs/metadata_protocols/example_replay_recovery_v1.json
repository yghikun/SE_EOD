{
  "schema_version": 1,
  "protocol_version": "1.0.0",
  "protocol_id": "mocc.replay_recovery.example",
  "filesystems": ["ext4", "xfs"],
  "linux_versions": [">=6.8"],
  "phases": ["ENTRY", "REPLAYING", "COMPLETE", "FAILED"],
  "operations": [
    {
      "operation_id": "replay_metadata",
      "entry_functions": ["example_replay_entry"],
      "principal_objects": [
        {
          "role": "metadata_object",
          "selector": "arg0"
        }
      ],
      "callee_roles": [
        {
          "role_id": "necessary_replay_step",
          "callees": ["example_replay_step"],
          "necessary": true,
          "return_contract_ids": [
            "replay.sentinel",
            "replay.failure",
            "replay.success"
          ]
        }
      ]
    }
  ],
  "return_contracts": [
    {
      "contract_id": "replay.sentinel",
      "operation_id": "replay_metadata",
      "guard": "ret == -ENOENT",
      "outcome": "expected_sentinel",
      "priority": 100
    },
    {
      "contract_id": "replay.failure",
      "operation_id": "replay_metadata",
      "guard": "ret < 0",
      "outcome": "failure",
      "priority": 10
    },
    {
      "contract_id": "replay.success",
      "operation_id": "replay_metadata",
      "guard": "ret == 0",
      "outcome": "success"
    }
  ],
  "effects": [
    {
      "event_id": "replay.effect.created",
      "effect_id": "replay.metadata_update",
      "operation_id": "replay_metadata",
      "kind": "METADATA_UPDATE",
      "object": {
        "role": "metadata_object",
        "selector": "arg0"
      },
      "scope": "PERSISTENT",
      "owner": "replay_metadata",
      "phase": "REPLAYING",
      "required": true,
      "description": "Representative persistent metadata replay effect."
    }
  ],
  "compensations": [
    {
      "event_id": "replay.effect.compensated",
      "compensation_id": "replay.metadata_rollback",
      "operation_id": "replay_metadata",
      "target_effect_id": "replay.metadata_update",
      "object": {
        "role": "metadata_object",
        "selector": "arg0"
      },
      "guard": "rollback_completed",
      "phase": "FAILED"
    }
  ],
  "handlers": [
    {
      "event_id": "replay.effect.delegated",
      "handler_id": "replay.recovery_handler",
      "operation_id": "replay_metadata",
      "completion_mode": "RECOVERY_DELEGATED",
      "object": {
        "role": "metadata_object",
        "selector": "arg0"
      },
      "owner": "recovery_subsystem",
      "guard": "recovery_registered",
      "handles_effect_ids": ["replay.metadata_update"]
    }
  ],
  "accounting_constraints": [
    {
      "constraint_id": "replay.pending_has_owner",
      "operation_id": "replay_metadata",
      "subject": {
        "role": "metadata_object",
        "selector": "arg0"
      },
      "expression": "pending_replay => owner_registered",
      "phases": ["REPLAYING"],
      "description": "Boolean M0 fixture for a future accounting obligation."
    }
  ],
  "legal_exits": [
    {
      "exit_id": "replay.success_exit",
      "operation_id": "replay_metadata",
      "kind": "success",
      "phases": ["COMPLETE"],
      "completion_modes": ["COMMITTED"],
      "return_outcomes": ["success"]
    },
    {
      "exit_id": "replay.failure_exit",
      "operation_id": "replay_metadata",
      "kind": "failure",
      "phases": ["FAILED"],
      "completion_modes": ["ROLLED_BACK", "RECOVERY_DELEGATED"],
      "return_outcomes": ["failure"]
    }
  ],
  "description": "M0 schema fixture for replay/recovery protocols."
}
