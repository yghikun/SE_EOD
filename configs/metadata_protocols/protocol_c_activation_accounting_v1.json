{
  "schema_version": 1,
  "protocol_version": "1.0.0",
  "protocol_id": "mocc.protocol_c.activation_accounting",
  "filesystems": ["ext4", "btrfs"],
  "linux_versions": [">=6.8"],
  "phases": ["ENTRY", "SUCCESS", "FAILURE"],
  "operations": [
    {
      "operation_id": "ext4_extra_isize_fallback",
      "entry_functions": ["ext4_expand_extra_isize_ea"],
      "principal_objects": [
        {"role": "inode", "selector": "arg0"}
      ],
      "callee_roles": [
        {
          "role_id": "inode_space_attempt",
          "callees": ["ext4_xattr_make_inode_space"],
          "necessary": true,
          "return_contract_ids": ["ext4.space.failure", "ext4.space.success"]
        }
      ]
    },
    {
      "operation_id": "btrfs_chunk_activation_reservation",
      "entry_functions": ["reserve_chunk_space"],
      "principal_objects": [
        {"role": "fs_info", "selector": "fs_info"}
      ],
      "callee_roles": [
        {
          "role_id": "chunk_activation",
          "callees": ["btrfs_zoned_activate_one_bg"],
          "necessary": true,
          "return_contract_ids": [
            "btrfs.activation.failure",
            "btrfs.activation.no_change",
            "btrfs.activation.changed"
          ]
        }
      ]
    }
  ],
  "return_contracts": [
    {
      "contract_id": "ext4.space.failure",
      "operation_id": "ext4_extra_isize_fallback",
      "guard": "ret != 0",
      "outcome": "failure"
    },
    {
      "contract_id": "ext4.space.success",
      "operation_id": "ext4_extra_isize_fallback",
      "guard": "ret == 0",
      "outcome": "success"
    },
    {
      "contract_id": "btrfs.activation.failure",
      "operation_id": "btrfs_chunk_activation_reservation",
      "guard": "ret < 0",
      "outcome": "failure"
    },
    {
      "contract_id": "btrfs.activation.no_change",
      "operation_id": "btrfs_chunk_activation_reservation",
      "guard": "ret == 0",
      "outcome": "success_no_change"
    },
    {
      "contract_id": "btrfs.activation.changed",
      "operation_id": "btrfs_chunk_activation_reservation",
      "guard": "ret > 0",
      "outcome": "success_changed"
    }
  ],
  "effects": [
    {
      "event_id": "ext4.extra_isize.changed",
      "effect_id": "ext4.inode_extra_isize_changed",
      "operation_id": "ext4_extra_isize_fallback",
      "kind": "METADATA_UPDATE",
      "object": {"role": "inode", "selector": "arg0"},
      "scope": "IN_MEMORY_GLOBAL",
      "owner": "ext4_expand_extra_isize_ea",
      "phase": "SUCCESS",
      "required": false,
      "match_fields": ["i_extra_isize"],
      "match_rhs": ["new_extra_isize"],
      "description": "The fallback path has changed the inode extra-isize state."
    },
    {
      "event_id": "btrfs.chunk.pending",
      "effect_id": "btrfs.chunk_metadata_pending",
      "operation_id": "btrfs_chunk_activation_reservation",
      "kind": "METADATA_UPDATE",
      "object": {"role": "fs_info", "selector": "fs_info"},
      "scope": "TRANSACTION_SCOPED",
      "owner": "reserve_chunk_space",
      "phase": "SUCCESS",
      "required": false,
      "match_callees": ["btrfs_zoned_activate_one_bg"],
      "match_results": ["ret"],
      "guard": "ret > 0",
      "description": "Positive activation success leaves pending chunk metadata work."
    },
    {
      "event_id": "btrfs.chunk.reserved",
      "effect_id": "btrfs.chunk_metadata_reserved",
      "operation_id": "btrfs_chunk_activation_reservation",
      "kind": "RESERVATION_UPDATE",
      "object": {"role": "fs_info", "selector": "fs_info"},
      "scope": "TRANSACTION_SCOPED",
      "owner": "chunk_block_rsv",
      "phase": "SUCCESS",
      "required": false,
      "match_callees": ["btrfs_block_rsv_add"],
      "match_results": ["ret"],
      "guard": "ret == 0",
      "description": "Chunk metadata reservation was successfully established."
    }
  ],
  "compensations": [],
  "handlers": [],
  "accounting_constraints": [
    {
      "constraint_id": "btrfs.pending_requires_reservation",
      "operation_id": "btrfs_chunk_activation_reservation",
      "subject": {"role": "fs_info", "selector": "fs_info"},
      "kind": "reservation",
      "expression": "pending metadata work exists => matching reservation exists",
      "phases": ["SUCCESS"],
      "trigger_effect_ids": ["btrfs.chunk_metadata_pending"],
      "satisfying_effect_ids": ["btrfs.chunk_metadata_reserved"],
      "description": "Boolean Protocol C MVP; no arbitrary arithmetic is inferred."
    }
  ],
  "legal_exits": [
    {
      "exit_id": "ext4.success",
      "operation_id": "ext4_extra_isize_fallback",
      "kind": "success",
      "phases": ["SUCCESS"],
      "completion_modes": ["COMMITTED"],
      "return_outcomes": ["success"]
    },
    {
      "exit_id": "ext4.failure",
      "operation_id": "ext4_extra_isize_fallback",
      "kind": "failure",
      "phases": ["FAILURE"],
      "completion_modes": ["ROLLED_BACK"],
      "return_outcomes": ["failure"]
    },
    {
      "exit_id": "btrfs.success",
      "operation_id": "btrfs_chunk_activation_reservation",
      "kind": "success",
      "phases": ["SUCCESS"],
      "completion_modes": ["COMMITTED"],
      "return_outcomes": ["success_no_change", "success_changed"]
    },
    {
      "exit_id": "btrfs.failure",
      "operation_id": "btrfs_chunk_activation_reservation",
      "kind": "failure",
      "phases": ["FAILURE"],
      "completion_modes": ["ROLLED_BACK"],
      "return_outcomes": ["failure"]
    }
  ],
  "description": "Protocol C MVP for stale fallback results and boolean activation/reservation accounting."
}
