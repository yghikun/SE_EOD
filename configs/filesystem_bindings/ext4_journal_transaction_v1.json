{
  "binding_schema_version": 1,
  "binding_id": "ext4.journal_transaction",
  "family_id": "transaction_lifecycle",
  "filesystem": "ext4",
  "linux_versions": ["6.8", "6.14", "7.1"],
  "role_bindings": {"resource": "journal_handle"},
  "actions": [
    {
      "action_id": "acquire",
      "callees": ["ext4_journal_start"],
      "object_binding": {
        "abstract_role": "resource",
        "source": "result",
        "normalization": "identity"
      },
      "guard": "!IS_ERR(ret)",
      "strength": "must",
      "max_call_depth": 1
    },
    {
      "action_id": "commit",
      "callees": ["ext4_journal_stop"],
      "object_binding": {
        "abstract_role": "resource",
        "source": "argument",
        "argument_index": 0,
        "normalization": "identity"
      },
      "guard": "always",
      "strength": "must",
      "max_call_depth": 1
    }
  ],
  "description": "Binds ext4 journal handle start and stop APIs to the transaction lifecycle family."
}
