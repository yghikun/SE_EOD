{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SE-EOD benchmark sample",
  "type": "object",
  "required": [
    "sample_id",
    "candidate_id",
    "linux_version",
    "filesystem",
    "file",
    "function",
    "error_line",
    "candidate_type",
    "annotation"
  ],
  "properties": {
    "sample_id": {"type": "string", "minLength": 1},
    "candidate_id": {"type": "string", "minLength": 1},
    "linux_version": {"type": "string", "minLength": 1},
    "filesystem": {"type": "string", "minLength": 1},
    "file": {"type": ["string", "null"]},
    "function": {"type": ["string", "null"]},
    "error_line": {"type": ["integer", "null"]},
    "path_id": {"type": ["string", "null"]},
    "candidate_type": {"type": "string", "minLength": 1},
    "severity": {"type": ["string", "null"]},
    "condition": {"type": ["string", "null"]},
    "final_return_expr": {"type": ["string", "null"]},
    "error_source_expr": {"type": ["string", "null"]},
    "target_label": {"type": ["string", "null"]},
    "annotation": {
      "type": "object",
      "required": ["verdict", "confidence", "reason", "evidence", "upstream_status", "reviewer", "reviewed_at"],
      "properties": {
        "verdict": {"type": ["string", "null"], "enum": ["true_bug", "false_positive", "uncertain", null]},
        "confidence": {"type": ["string", "null"], "enum": ["high", "medium", "low", null]},
        "reason": {"type": ["string", "null"]},
        "evidence": {"type": "array", "items": {"type": "string"}},
        "upstream_status": {"type": "string"},
        "reviewer": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
