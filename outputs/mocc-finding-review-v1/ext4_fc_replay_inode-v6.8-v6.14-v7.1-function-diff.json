      "unified_diff": [
        "--- v6.14:linux-sources/linux-v6.14-fs/fs/ext4/fast_commit.c",
        "+++ v7.1:linux-sources/linux-v7.1-fs/fs/ext4/fast_commit.c",
        "@@ -56,19 +56,21 @@",
        " \t/* Immediately update the inode on disk. */",
        " \tret = ext4_handle_dirty_metadata(NULL, NULL, iloc.bh);",
        " \tif (ret)",
        "-\t\tgoto out;",
        "+\t\tgoto out_brelse;",
        " \tret = sync_dirty_buffer(iloc.bh);",
        " \tif (ret)",
        "-\t\tgoto out;",
        "+\t\tgoto out_brelse;",
        " \tret = ext4_mark_inode_used(sb, ino);",
        " \tif (ret)",
        "-\t\tgoto out;",
        "+\t\tgoto out_brelse;",
        " ",
        " \t/* Given that we just wrote the inode on disk, this SHOULD succeed. */",
        " \tinode = ext4_iget(sb, ino, EXT4_IGET_NORMAL);",
        " \tif (IS_ERR(inode)) {",
        " \t\text4_debug(\"Inode not found.\");",
        "-\t\treturn -EFSCORRUPTED;",
        "+\t\tinode = NULL;",
        "+\t\tret = -EFSCORRUPTED;",
        "+\t\tgoto out_brelse;",
        " \t}",
        " ",
        " \t/*",
        "@@ -85,11 +87,12 @@",
        " \text4_inode_csum_set(inode, ext4_raw_inode(&iloc), EXT4_I(inode));",
        " \tret = ext4_handle_dirty_metadata(NULL, NULL, iloc.bh);",
        " \tsync_dirty_buffer(iloc.bh);",
        "+out_brelse:",
        " \tbrelse(iloc.bh);",
        " out:",
        " \tiput(inode);",
        " \tif (!ret)",
        " \t\tblkdev_issue_flush(sb->s_bdev);",
        " ",
        "-\treturn 0;",
        "+\treturn ret;",
        " }"
      ],
